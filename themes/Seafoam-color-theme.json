{
    "name": "Seafoam",
    "colors": {
        "editor.background": "#e5f7ed",
        "editor.foreground": "#095209",
        "activityBar.background": "#d0ebd9",
        "activityBar.foreground": "#095209",
        "activityBarBadge.background": "#921010",
        "activityBarBadge.foreground": "#ffffff",
        "sideBar.background": "#dcf2e5",
        "sideBar.foreground": "#095209",
        "sideBarTitle.foreground": "#095209",
        "editorLineNumber.foreground": "#09523a",
        "editorCursor.foreground": "#921010",
        "editor.selectionBackground": "#9ce6bc",
        "statusBar.background": "#d0ebd9",
        "statusBar.foreground": "#095209",
        "terminal.background": "#e5f7ed",
        "terminal.foreground": "#095209",
        "list.activeSelectionBackground": "#9ce6bc",
        "list.hoverBackground": "#c1e8d2"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#494949"
            }
        },
        {
            "name": "All Keywords",
            "scope": [
                "keyword"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#921010"
            }
        },
        {
            "name": "Control Flow (Keywords)",
            "scope": [
                "keyword.control",
                "keyword.operator.new",
                "keyword.operator.logical",
                "keyword.operator.expression"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#921010"
            }
        },
        {
            "name": "Operators, Braces, Brackets, Parentheses",
            "scope": [
                "keyword.operator",
                "punctuation.definition.parameters",
                "punctuation.definition.array",
                "punctuation.definition.dictionary",
                "punctuation.definition.block",
                "punctuation.section.embedded",
                "meta.brace.round",
                "meta.brace.square",
                "meta.brace.curly"
            ],
            "settings": {
                "fontStyle": "",
                "foreground": "#5b470a"
            }
        },
        {
            "name": "Mutable Elements (Variables, Parameters)",
            "scope": [
                "variable",
                "variable.parameter"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#494908"
            }
        },
        {
            "name": "Strings",
            "scope": [
                "string"
            ],
            "settings": {
                "foreground": "#6e3d0c"
            }
        },
        {
            "name": "Functions",
            "scope": [
                "entity.name.function",
                "meta.function-call"
            ],
            "settings": {
                "foreground": "#1141a0"
            }
        },
        {
            "name": "Types / Classes (Built-in and User Defined)",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "support.type",
                "support.class"
            ],
            "settings": {
                "fontStyle": "underline",
                "foreground": "#6514b7"
            }
        },
        {
            "name": "Constants / Numbers",
            "scope": [
                "constant",
                "constant.numeric",
                "constant.language",
                "support.constant"
            ],
            "settings": {
                "foreground": "#800e80"
            }
        },
        {
            "name": "Language Specific: Python Function Storage",
            "scope": [
                "storage.type.function.python"
            ],
            "settings": {
                "fontStyle": "bold underline",
                "foreground": "#1141a0"
            }
        },
        {
            "name": "Language Specific: C++ Mutable Elements",
            "scope": [
                "variable.other.readwrite.cpp"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#494908"
            }
        },
        {
            "name": "Language Specific: Markdown Headers",
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#095252"
            }
        },
        {
            "name": "Language Specific: Markdown Bold/Italic",
            "scope": [
                "markup.bold",
                "markup.italic"
            ],
            "settings": {
                "foreground": "#800e80"
            }
        },
        {
            "name": "Language Specific: F# Variable",
            "scope": [
                "variable.fsharp"
            ],
            "settings": {
                "fontStyle": "italic underline",
                "foreground": "#494908"
            }
        },
        {
            "name": "Language Specific: Ada Keywords",
            "scope": [
                "keyword.other.ada"
            ],
            "settings": {
                "fontStyle": "bold underline",
                "foreground": "#921010"
            }
        }
    ]
}
