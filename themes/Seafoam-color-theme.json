{
    "name": "Seafoam",
    "colors": {
        "editor.background": "#e5f7ed",
        "editor.foreground": "#095209",
        "activityBar.background": "#d0ebd9",
        "activityBar.foreground": "#095209",
        "activityBarBadge.background": "#921010",
        "activityBarBadge.foreground": "#ffffff",
        "sideBar.background": "#dcf2e5",
        "sideBar.foreground": "#095209",
        "sideBarTitle.foreground": "#095209",
        "editorLineNumber.foreground": "#09523a",
        "editorCursor.foreground": "#921010",
        "editor.selectionBackground": "#9ce6bc",
        "statusBar.background": "#d0ebd9",
        "statusBar.foreground": "#095209",
        "terminal.background": "#e5f7ed",
        "terminal.foreground": "#095209",
        "list.activeSelectionBackground": "#9ce6bc",
        "list.hoverBackground": "#c1e8d2"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#494949"
            }
        },
        {
            "name": "All Keywords",
            "scope": [
                "keyword"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#921010"
            }
        },
        {
            "name": "Control Flow (Keywords)",
            "scope": [
                "keyword.control",
                "keyword.operator.new",
                "keyword.operator.logical",
                "keyword.operator.expression",
                "keyword.control.ada",
                "keyword.other.ada",
                "keyword.control.flow.python",
                "keyword.control.import.python",
                "keyword.control.directive.cpp",
                "keyword.control.switch.cpp",
                "keyword.control.goto.cpp",
                "keyword.control.fsharp",
                "keyword.fsharp"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#921010"
            }
        },
        {
            "name": "Operators, Braces, Brackets, Parentheses (Strict NO EMPHASIS)",
            "scope": [
                "keyword.operator",
                "punctuation.definition.parameters",
                "punctuation.definition.array",
                "punctuation.definition.dictionary",
                "punctuation.definition.block",
                "punctuation.section.embedded",
                "meta.brace.round",
                "meta.brace.square",
                "meta.brace.curly",
                "keyword.operator.arithmetic.cpp",
                "keyword.operator.assignment.cpp",
                "keyword.operator.arithmetic.python",
                "keyword.operator.assignment.python",
                "entity.name.operator.ada",
                "keyword.symbol.fsharp"
            ],
            "settings": {
                "fontStyle": "",
                "foreground": "#5b470a"
            }
        },
        {
            "name": "Mutable Elements (Variables, Parameters)",
            "scope": [
                "variable",
                "variable.parameter",
                "variable.name.ada",
                "entity.name.variable.ada",
                "variable.parameter.function.language.python",
                "variable.other.readwrite.cpp",
                "variable.other.local.cpp"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#494908"
            }
        },
        {
            "name": "Mutable F# Specific",
            "scope": [
                "variable.fsharp",
                "variable.other.binding.fsharp",
                "variable.parameter.fsharp"
            ],
            "settings": {
                "fontStyle": "italic underline",
                "foreground": "#494908"
            }
        },
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.quoted.double.ada",
                "markup.inline.raw.string.markdown"
            ],
            "settings": {
                "foreground": "#6e3d0c"
            }
        },
        {
            "name": "Functions",
            "scope": [
                "entity.name.function",
                "meta.function-call",
                "entity.name.function.ada",
                "entity.name.subprogram.ada",
                "entity.name.function.call.cpp",
                "entity.name.function.definition.cpp",
                "entity.name.function.python"
            ],
            "settings": {
                "foreground": "#1141a0"
            }
        },
        {
            "name": "Functions Python Specific (Definition)",
            "scope": [
                "storage.type.function.python"
            ],
            "settings": {
                "fontStyle": "bold underline",
                "foreground": "#1141a0"
            }
        },
        {
            "name": "Types / Classes (Built-in and User Defined)",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "support.type",
                "support.class",
                "entity.name.type.cpp",
                "entity.name.type.class.cpp",
                "entity.name.type.class.python",
                "entity.name.type.fsharp",
                "entity.name.type.namespace.fsharp",
                "entity.name.type.ada"
            ],
            "settings": {
                "fontStyle": "underline",
                "foreground": "#6514b7"
            }
        },
        {
            "name": "Constants / Numbers",
            "scope": [
                "constant",
                "constant.numeric",
                "constant.language",
                "support.constant"
            ],
            "settings": {
                "foreground": "#800e80"
            }
        },
        {
            "name": "Markdown Headers",
            "scope": [
                "heading.1.markdown",
                "heading.2.markdown",
                "heading.3.markdown",
                "heading.4.markdown",
                "heading.5.markdown",
                "heading.6.markdown",
                "markup.heading.markdown",
                "markup.heading.setext.1.markdown",
                "markup.heading.setext.2.markdown"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#095252"
            }
        },
        {
            "name": "Markdown Bold/Italic",
            "scope": [
                "markup.bold.markdown",
                "markup.italic.markdown"
            ],
            "settings": {
                "foreground": "#800e80"
            }
        },
        {
            "name": "Markdown Lists and Quotes",
            "scope": [
                "markup.list.numbered.markdown",
                "markup.list.unnumbered.markdown",
                "markup.quote.markdown"
            ],
            "settings": {
                "foreground": "#09523a"
            }
        }
    ]
}
